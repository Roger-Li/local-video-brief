OVS_APP_NAME=Local Video Brief
OVS_DATABASE_PATH=data/local_video_brief.sqlite3
OVS_ARTIFACT_ROOT=artifacts
OVS_WORKER_POLL_INTERVAL=2
OVS_DEFAULT_OUTPUT_LANGUAGES=en,zh-CN
OVS_PREFERRED_CAPTION_LANGUAGES=en,zh-Hans,zh-Hant,zh-CN,zh-TW
OVS_SUMMARIZER_MODEL=mlx-community/Qwen3.5-9B-Instruct-4bit
OVS_SUMMARIZER_MAX_INPUT_CHARS=18000
OVS_ENABLE_MLX_SUMMARIZER=false
OVS_ENABLE_MLX_ASR=false
OVS_ASR_MODEL=mlx-community/whisper-large-v3-turbo
OVS_MAX_CHAPTER_MINUTES=8
